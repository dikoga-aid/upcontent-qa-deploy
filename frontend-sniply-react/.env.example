# Sniply (React) SPA configuration. Copy to .env. NEVER commit .env.
# These are PUBLIC values (shipped to the browser) — no secret here.

VITE_AUTH0_DOMAIN=dev-rvvkxpvy18wueufd.us.auth0.com
# SPA client_id of the Auth0 "Sniply" application (see the README env map).
VITE_AUTH0_CLIENT_ID=your-sniply-spa-client-id
# Sniply's own API audience (separate from UpContent); the backend accepts both.
VITE_AUTH0_AUDIENCE=https://sniply-api
VITE_API_BASE_URL=http://localhost:3003
