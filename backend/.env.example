# Backend (FastAPI resource server) configuration.
# Copy to .env and fill in real values. NEVER commit .env.

# Auth0 tenant + this API's audience (the Auth0 API identifier).
AUTH0_DOMAIN=dev-rvvkxpvy18wueufd.us.auth0.com
AUTH0_API_AUDIENCE=https://upcontent-api

# Machine-to-Machine client authorized for the Auth0 Management API.
# Server-side ONLY. Used to mint Management tokens. Do NOT expose to browsers.
AUTH0_MGMT_CLIENT_ID=your-m2m-client-id
AUTH0_MGMT_CLIENT_SECRET=your-m2m-client-secret

# SPA client_id (so org invitation links target the right app).
# Fill with the SPA client_id from Auth0 (see provision_auth0.py / README).
AUTH0_SPA_CLIENT_ID=your-spa-client-id

# Strict CORS allow-list — the two Vite dev origins.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Server
PORT=5000
PRODUCTION=false
