# Backend (FastAPI resource server) configuration.
# Copy to .env and add the M2M client secret below. NEVER commit .env.

# Auth0 tenant. Accepted API audiences are comma-separated (per-app split):
# UpContent SPA -> https://upcontent-api, Sniply SPA -> https://sniply-api.
AUTH0_DOMAIN=dev-rvvkxpvy18wueufd.us.auth0.com
AUTH0_API_AUDIENCE=https://upcontent-api,https://sniply-api

# Machine-to-Machine client authorized for the Auth0 Management API
# (the "UpC Services - MGM API" app). Server-side ONLY; mints Management tokens.
# Do NOT expose to browsers.
AUTH0_MGMT_CLIENT_ID=Hl9n0lCy71RHTF6fIvD53Jo6rUDSVRYa
AUTH0_MGMT_CLIENT_SECRET=your-m2m-client-secret

# SPA client_id used as the target of org invitation links (the "UpContent SPA" app).
AUTH0_SPA_CLIENT_ID=Non4DMjqQ1dZK4uxXgg3u6i6Sb5Bt1Yg

# Strict CORS allow-list — the two Vite dev origins.
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Server
PORT=3003
PRODUCTION=false
